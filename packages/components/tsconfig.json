{
  "extends": "../../tsconfig.base.json",
  "include": ["./src/**/*.ts", "./src/**/*.tsx"],
  "exclude": [
    "./types",
    "./esm",
    "./cjs",
    "node_modules",
    "./dist",
    "./src/__mocks__"
  ],
  "compilerOptions": {
    "rootDir": "src",
    "baseUrl": ".",
    "declarationDir": "types",
    "outDir": "dist",
    "moduleResolution": "Bundler"
  },
  "references": [
    { "path": "../contexts" },
    { "path": "../hooks" },
    { "path": "../utils" }
  ]
}
